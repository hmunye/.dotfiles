#!/usr/bin/env bash

set -euo pipefail

trap "docker stop open-webui searxng >/dev/null || true" EXIT SIGINT SIGTERM

if docker ps -a --format '{{.Names}}' | grep -q '^open-webui$'; then
    docker start open-webui >/dev/null
else
    mkdir -p "$HOME/.open-webui"

    docker run -d \
      --network=host \
      -v "$HOME/.open-webui:/app/backend/data" \
      -e OLLAMA_BASE_URL=http://127.0.0.1:11434 \
      --name open-webui \
      --restart always \
      ghcr.io/open-webui/open-webui:main \
      >/dev/null
fi

if docker ps -a --format '{{.Names}}' | grep -q '^searxng$'; then
    docker start searxng >/dev/null
else
    mkdir -p "$HOME/.searxng"

    docker run -d \
      -p 127.0.0.1:8081:8080 \
      -v "$HOME/.searxng:/etc/searxng:rw" \
      --name searxng \
      --restart unless-stopped \
      searxng/searxng:latest \
      >/dev/null
fi

while ! nc -z -w 1 localhost 8080 >/dev/null 2>&1; do
    sleep 0.5
done

while ! nc -z -w 1 localhost 8081 >/dev/null 2>&1; do
    sleep 0.5
done

if command -v xdg-open >/dev/null; then
    xdg-open http://localhost:8080
else
    echo -e "\n-> http://localhost:8080\n"
fi

ollama serve
